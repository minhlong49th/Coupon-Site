// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ──────────────────────────────────────────────────────────────────

enum CouponStatus {
  ACTIVE
  EXPIRED
  PENDING
  REJECTED
}

enum CouponType {
  PERCENT
  FIXED
  FREE_SHIPPING
  BOGO
  OTHER
}

enum UserRole {
  SUPER_ADMIN
  EDITOR
  MODERATOR
  USER
}

enum VoteValue {
  UP
  DOWN
}

// ── Models ─────────────────────────────────────────────────────────────────

// User công khai trên website (khác AdminUser — AdminUser chỉ dành cho
// /admin, User ở đây là người dùng cuối: submit coupon, vote, nhận karma).
// THIẾU MODEL NÀY LÀ LỖ HỔNG: nếu không có User + Vote riêng, không có
// cách nào enforce "1 vote / user / coupon" ở tầng database — hệ thống
// sẽ chỉ dựa vào localStorage/client state, dễ bị spam vote bằng cách
// xoá cache hoặc gọi API trực tiếp.
model User {
  id          String       @id @default(cuid())
  clerkId     String       @unique
  username    String       @unique
  email       String       @unique
  karma       Int          @default(0)
  isBanned    Boolean      @default(false)   // chặn user spam/abuse mà không cần xoá tài khoản
  submitted   Coupon[]     @relation("CouponSubmitter")
  votes       Vote[]
  clicks      CouponClick[]
  karmaEvents KarmaEvent[]
  mediaAssets MediaAsset[]
  posts       Post[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([karma])
}

model Brand {
  id           String    @id @default(cuid())
  name         String
  slug         String    @unique
  domain       String    @unique
  logoUrl      String?
  affiliateUrl String
  category     String
  description  String?
  isActive     Boolean   @default(true)
  coupons      Coupon[]
  posts        PostBrand[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([category])
  @@index([slug])
}

model Coupon {
  id              String        @id @default(cuid())
  brand           Brand         @relation(fields: [brandId], references: [id])
  brandId         String
  code            String
  title           String
  description     String?
  type            CouponType
  discountValue   Float?
  affiliateUrl    String
  status          CouponStatus  @default(PENDING)
  expiresAt       DateTime?
  successRate     Int           @default(0)   // 0–100, tính lại từ Vote mỗi khi có vote mới
  useCount        Int           @default(0)
  clickCount      Int           @default(0)
  isFeatured      Boolean       @default(false)
  submitter       User?         @relation("CouponSubmitter", fields: [submitterId], references: [id])
  submitterId     String?       // null = do Admin tự thêm (Quick Add), không null = user submit
  verifiedAt      DateTime?
  clicks          CouponClick[]
  votes           Vote[]
  posts           PostCoupon[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([brandId, code])
  @@index([status])
  @@index([brandId])
  @@index([expiresAt])
  @@index([isFeatured])
}

// Bắt buộc phải có model riêng cho vote (không chỉ cộng/trừ số trên Coupon)
// để DB tự chặn double-vote qua @@unique, và để có thể đổi vote (toggle)
// hoặc audit lại nếu nghi ngờ bị brigade/vote thao túng.
model Vote {
  id        String    @id @default(cuid())
  coupon    Coupon    @relation(fields: [couponId], references: [id])
  couponId  String
  user      User      @relation(fields: [userId], references: [id])
  userId    String
  value     VoteValue
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([couponId, userId])  // enforce 1 vote / user / coupon ở tầng DB
  @@index([couponId])
}

model CouponClick {
  id         String   @id @default(cuid())
  coupon     Coupon   @relation(fields: [couponId], references: [id])
  couponId   String
  user       User?    @relation(fields: [userId], references: [id])
  userId     String?
  ipHash     String?
  userAgent  String?
  source     String?  // "organic" | "direct" | "referral" | "social"
  utm        Json?
  createdAt  DateTime @default(now())

  @@index([couponId])
  @@index([createdAt])
}

model KarmaEvent {
  id          String   @id @default(cuid())
  user        User     @relation(fields: [userId], references: [id])
  userId      String
  action      String   // "SUBMIT_COUPON" | "COUPON_VERIFIED" | "VOTE" | "FAKE_COUPON"
  points      Int
  referenceId String?  // couponId hoặc brandId liên quan
  createdAt   DateTime @default(now())

  @@index([userId])
}

model AdminUser {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String   @unique
  name      String
  role      UserRole @default(EDITOR)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id          String   @id @default(cuid())
  adminId     String?  // nullable for system actions
  action      String   // e.g. "UPDATE_COUPON", "DELETE_BRAND"
  entityType  String   // e.g. "COUPON", "BRAND"
  entityId    String
  details     Json?    // old/new values, etc.
  createdAt   DateTime @default(now())

  @@index([adminId])
  @@index([entityType, entityId])
}

// ============================================================
// MEDIA MODULE
// ============================================================

enum MediaType {
  IMAGE
  VIDEO
  DOCUMENT
  OTHER
}

model MediaAsset {
  id          String    @id @default(cuid())

  // File info
  filename    String                        // tên file gốc
  key         String    @unique             // Uploadthing key (dùng để xóa)
  url         String                        // URL CDN gốc (full resolution)
  mimeType    String                        // image/jpeg, image/png, image/webp, v.v.
  size        Int                           // bytes
  mediaType   MediaType @default(IMAGE)

  // Image dimensions (null nếu không phải ảnh)
  width       Int?
  height      Int?

  // SEO / Accessibility
  alt         String?                       // alt text
  caption     String?                       // caption hiển thị dưới ảnh
  title       String?                       // internal title để tìm kiếm

  // Variants — lưu dạng JSON
  // { thumbnail: { url, width, height }, card: { url, width, height }, og: { url, width, height } }
  variants    Json?

  // Folder / organization
  folder      String?   @default("uploads") // virtual folder

  // Relations
  uploadedById String
  uploadedBy   User     @relation(fields: [uploadedById], references: [id])

  // Bài viết dùng asset này làm thumbnail
  postThumbnails Post[] @relation("PostThumbnail")

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([mediaType, createdAt])
  @@index([folder])
  @@index([mimeType])
  @@map("media_assets")
}

// ============================================================
// BLOG MODULE
// ============================================================

enum PostStatus {
  DRAFT
  PUBLISHED
  SCHEDULED
  ARCHIVED
}

enum ContentType {
  RICH_TEXT   // Tiptap JSON
  MARKDOWN    // Raw markdown string
}

model Post {
  id            String      @id @default(cuid())
  title         String
  slug          String      @unique
  content       Json        // Tiptap JSON hoặc markdown string dạng { type: "md", body: "..." }
  contentType   ContentType @default(RICH_TEXT)
  excerpt       String?     @db.Text
  
  thumbnailId   String?
  thumbnail     MediaAsset? @relation("PostThumbnail", fields: [thumbnailId], references: [id])
  thumbnailUrl  String?

  status        PostStatus  @default(DRAFT)
  publishedAt   DateTime?
  scheduledAt   DateTime?   // Thời điểm tự động publish

  // SEO
  seoTitle      String?
  seoDesc       String?     @db.VarChar(160)
  ogImage       String?

  // Stats
  readingTime   Int?        // Phút đọc ước tính
  viewCount     Int         @default(0)

  // Relations
  authorId      String
  author        User        @relation(fields: [authorId], references: [id])
  categories    CategoriesOnPosts[]
  tags          TagsOnPosts[]
  coupons       PostCoupon[]
  brands        PostBrand[]

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([status, publishedAt])
  @@index([slug])
  @@map("posts")
}

model Category {
  id          String              @id @default(cuid())
  name        String
  slug        String              @unique
  description String?
  posts       CategoriesOnPosts[]

  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@map("categories")
}

model Tag {
  id        String        @id @default(cuid())
  name      String
  slug      String        @unique
  posts     TagsOnPosts[]

  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@map("tags")
}

// Join table: Post <-> Category (many-to-many)
model CategoriesOnPosts {
  post       Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId     String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  categoryId String

  @@id([postId, categoryId])
  @@map("categories_on_posts")
}

// Join table: Post <-> Tag (many-to-many)
model TagsOnPosts {
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId String
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)
  tagId  String

  @@id([postId, tagId])
  @@map("tags_on_posts")
}

// Coupon nhúng vào bài viết
model PostCoupon {
  id        String  @id @default(cuid())
  post      Post    @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId    String
  // Tham chiếu sang model Coupon đã có trong hệ thống
  couponId  String
  coupon    Coupon  @relation(fields: [couponId], references: [id])
  position  Int?    // Thứ tự hiển thị trong bài (0-indexed)
  note      String? // Ghi chú bổ sung hiển thị kèm coupon

  @@unique([postId, couponId])
  @@map("post_coupons")
}

// Brand gắn với bài viết
model PostBrand {
  post      Post    @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId    String
  // Tham chiếu sang model Brand đã có trong hệ thống
  brandId   String
  brand     Brand   @relation(fields: [brandId], references: [id])
  isPrimary Boolean @default(false) // Brand chính hiện logo đầu bài

  @@id([postId, brandId])
  @@map("post_brands")
}
