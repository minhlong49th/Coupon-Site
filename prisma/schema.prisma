// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ──────────────────────────────────────────────────────────────────

enum CouponStatus {
  ACTIVE
  EXPIRED
  PENDING
  REJECTED
}

enum CouponType {
  PERCENT
  FIXED
  FREE_SHIPPING
  BOGO
  OTHER
}

enum UserRole {
  SUPER_ADMIN
  EDITOR
  MODERATOR
  USER
}

enum VoteValue {
  UP
  DOWN
}

// ── Models ─────────────────────────────────────────────────────────────────

// User công khai trên website (khác AdminUser — AdminUser chỉ dành cho
// /admin, User ở đây là người dùng cuối: submit coupon, vote, nhận karma).
// THIẾU MODEL NÀY LÀ LỖ HỔNG: nếu không có User + Vote riêng, không có
// cách nào enforce "1 vote / user / coupon" ở tầng database — hệ thống
// sẽ chỉ dựa vào localStorage/client state, dễ bị spam vote bằng cách
// xoá cache hoặc gọi API trực tiếp.
model User {
  id          String       @id @default(cuid())
  clerkId     String       @unique
  username    String       @unique
  email       String       @unique
  karma       Int          @default(0)
  isBanned    Boolean      @default(false)   // chặn user spam/abuse mà không cần xoá tài khoản
  submitted   Coupon[]     @relation("CouponSubmitter")
  votes       Vote[]
  clicks      CouponClick[]
  karmaEvents KarmaEvent[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([karma])
}

model Brand {
  id           String    @id @default(cuid())
  name         String
  slug         String    @unique
  domain       String    @unique
  logoUrl      String?
  affiliateUrl String
  category     String
  description  String?
  isActive     Boolean   @default(true)
  coupons      Coupon[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([category])
  @@index([slug])
}

model Coupon {
  id              String        @id @default(cuid())
  brand           Brand         @relation(fields: [brandId], references: [id])
  brandId         String
  code            String
  title           String
  description     String?
  type            CouponType
  discountValue   Float?
  affiliateUrl    String
  status          CouponStatus  @default(PENDING)
  expiresAt       DateTime?
  successRate     Int           @default(0)   // 0–100, tính lại từ Vote mỗi khi có vote mới
  useCount        Int           @default(0)
  clickCount      Int           @default(0)
  isFeatured      Boolean       @default(false)
  submitter       User?         @relation("CouponSubmitter", fields: [submitterId], references: [id])
  submitterId     String?       // null = do Admin tự thêm (Quick Add), không null = user submit
  verifiedAt      DateTime?
  clicks          CouponClick[]
  votes           Vote[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([brandId, code])
  @@index([status])
  @@index([brandId])
  @@index([expiresAt])
  @@index([isFeatured])
}

// Bắt buộc phải có model riêng cho vote (không chỉ cộng/trừ số trên Coupon)
// để DB tự chặn double-vote qua @@unique, và để có thể đổi vote (toggle)
// hoặc audit lại nếu nghi ngờ bị brigade/vote thao túng.
model Vote {
  id        String    @id @default(cuid())
  coupon    Coupon    @relation(fields: [couponId], references: [id])
  couponId  String
  user      User      @relation(fields: [userId], references: [id])
  userId    String
  value     VoteValue
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([couponId, userId])  // enforce 1 vote / user / coupon ở tầng DB
  @@index([couponId])
}

model CouponClick {
  id         String   @id @default(cuid())
  coupon     Coupon   @relation(fields: [couponId], references: [id])
  couponId   String
  user       User?    @relation(fields: [userId], references: [id])
  userId     String?
  ipHash     String?
  userAgent  String?
  source     String?  // "organic" | "direct" | "referral" | "social"
  utm        Json?
  createdAt  DateTime @default(now())

  @@index([couponId])
  @@index([createdAt])
}

model KarmaEvent {
  id          String   @id @default(cuid())
  user        User     @relation(fields: [userId], references: [id])
  userId      String
  action      String   // "SUBMIT_COUPON" | "COUPON_VERIFIED" | "VOTE" | "FAKE_COUPON"
  points      Int
  referenceId String?  // couponId hoặc brandId liên quan
  createdAt   DateTime @default(now())

  @@index([userId])
}

model AdminUser {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String   @unique
  name      String
  role      UserRole @default(EDITOR)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id          String   @id @default(cuid())
  adminId     String?  // nullable for system actions
  action      String   // e.g. "UPDATE_COUPON", "DELETE_BRAND"
  entityType  String   // e.g. "COUPON", "BRAND"
  entityId    String
  details     Json?    // old/new values, etc.
  createdAt   DateTime @default(now())

  @@index([adminId])
  @@index([entityType, entityId])
}
